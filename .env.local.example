# ─────────────────────────────────────────────────────────
# FSOS Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────────────────

# Supabase — get from supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Key — server-side ONLY, never expose to client
SUPABASE_SERVICE_KEY=your-service-key-here

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key-here

# Resend — get from resend.com → API Keys
RESEND_API_KEY=your-resend-key-here
RESEND_FROM_EMAIL=forms@yourdomain.com

# App URL — your Vercel deployment URL
NEXT_PUBLIC_URL=https://your-app.vercel.app

# Agency referral base URL — can be same as NEXT_PUBLIC_URL
NEXT_PUBLIC_REFERRAL_BASE_URL=https://fsa.protecwise.com

# GHL (GoHighLevel) — for webhook integrations
GHL_API_KEY=your-ghl-api-key
GHL_LOCATION_ID=your-ghl-location-id
GHL_WEBHOOK_SECRET=your-webhook-secret

# Optional: Twilio (if sending SMS directly rather than through GHL)
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+18005550000
