# ─────────────────────────────────────────────────────────
# FSOS Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────────────────

# Supabase — get from supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Key — server-side ONLY, never expose to client
SUPABASE_SERVICE_KEY=your-service-key-here

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key-here

# Resend — get from resend.com → API Keys
RESEND_API_KEY=your-resend-key-here
RESEND_FROM_EMAIL=forms@yourdomain.com
# Recipient for the AI morning briefing (POST /api/briefing/send). Defaults to RESEND_FROM_EMAIL.
BRIEFING_TO_EMAIL=you@yourdomain.com

# App URL — your Vercel deployment URL
NEXT_PUBLIC_URL=https://your-app.vercel.app

# Calendly — appointment booking (replaces GHL calendar + booking webhook)
# Calendly → Integrations → Webhooks → signing key
CALENDLY_WEBHOOK_SECRET=your-calendly-signing-key
# Reserved for a future in-app Calendly embed; not currently used in emails. Public-safe.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username

# Twilio — direct SMS (replaces GHL LeadConnector SMS)
# twilio.com → Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+14695550001

# Retell AI — voice agents (replaces GHL AI Employee for inbound/outbound calls)
# retellai.com → Dashboard → API Key. Used for agent config; not wired into API routes yet.
RETELL_API_KEY=your-retell-api-key

# ─────────────────────────────────────────────────────────
# GoHighLevel — pipeline & workflow engine (WF-0…WF-43)
# Location: Markist Athelus Agency. Leave GHL_API_KEY blank to disable all GHL
# writes (the app degrades gracefully; the referral sync and /api/ghl/sync
# no-op). The inbound webhook still records events when a secret is set.
# ─────────────────────────────────────────────────────────
# Private Integration / API token (Settings → Private Integrations, scopes:
# contacts.write, opportunities.write, conversations.write). LeadConnector v2.
GHL_API_KEY=your-ghl-private-integration-token
# Sub-account (location) id — defaults to ATDNO1e5d27nj5t8vId3 if unset.
GHL_LOCATION_ID=ATDNO1e5d27nj5t8vId3
# Shared secret used to HMAC-SHA256-verify inbound webhooks (x-ghl-signature).
GHL_WEBHOOK_SECRET=your-ghl-webhook-secret

# ─────────────────────────────────────────────────────────
# Auth gate — protects the command-center UI and internal API routes
# ─────────────────────────────────────────────────────────

# Basic-auth username for the command-center login gate. Defaults to `markist`.
FSOS_ADMIN_USER=markist

# Basic-auth password. SET THIS to enable the command-center login gate
# (middleware) and internal-API protection. Leave blank to keep everything open
# (e.g. local dev). Setting either this or FSOS_API_SECRET turns protection on.
FSOS_ADMIN_PASSWORD=

# Bearer token that server-to-server callers (Make.com scenarios, cron jobs)
# send as `Authorization: Bearer <value>` to reach internal API routes.
# Use any long random string.
FSOS_API_SECRET=your-internal-api-secret

# Apollo.io — contact enrichment (title, company, LinkedIn). Get from
# apollo.io → Settings → Integrations → API. Leave blank to disable the
# "Enrich" action (it degrades gracefully).
APOLLO_API_KEY=your-apollo-api-key
